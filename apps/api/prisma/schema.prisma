// Edin Platform — Prisma Schema
// Domain-separated PostgreSQL schemas: core, evaluation, publication, audit

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["core", "evaluation", "publication", "audit"]
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum ContributorRole {
  PUBLIC
  APPLICANT
  CONTRIBUTOR
  EDITOR
  FOUNDING_CONTRIBUTOR
  WORKING_GROUP_LEAD
  ADMIN

  @@schema("core")
}

enum ContributorDomain {
  Technology
  Finance
  Impact
  Governance

  @@schema("core")
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  DECLINED

  @@schema("core")
}

enum ReviewRecommendation {
  APPROVE
  REQUEST_MORE_INFO
  DECLINE

  @@schema("core")
}

enum OnboardingMilestoneType {
  ACCOUNT_ACTIVATED
  BUDDY_ASSIGNED
  FIRST_TASK_VIEWED
  FIRST_TASK_CLAIMED
  FIRST_CONTRIBUTION_SUBMITTED

  @@schema("core")
}

enum RepositoryStatus {
  ACTIVE
  PENDING
  ERROR
  REMOVING

  @@schema("core")
}

enum ContributionSource {
  GITHUB

  @@schema("core")
}

enum ContributionType {
  COMMIT
  PULL_REQUEST
  CODE_REVIEW
  DOCUMENTATION

  @@schema("core")
}

enum ContributionStatus {
  INGESTED
  ATTRIBUTED
  UNATTRIBUTED
  EVALUATED

  @@schema("core")
}

enum CollaborationRole {
  PRIMARY_AUTHOR
  CO_AUTHOR
  COMMITTER
  ISSUE_ASSIGNEE

  @@schema("core")
}

enum CollaborationStatus {
  DETECTED
  CONFIRMED
  DISPUTED
  OVERRIDDEN

  @@schema("core")
}

enum WebhookDeliveryStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  FAILED

  @@schema("core")
}

enum TaskStatus {
  AVAILABLE
  CLAIMED
  IN_PROGRESS
  COMPLETED
  EVALUATED
  RETIRED

  @@schema("core")
}

enum TaskDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED

  @@schema("core")
}

enum ActivityEventType {
  CONTRIBUTION_NEW
  EVALUATION_COMPLETED
  ANNOUNCEMENT_CREATED
  MEMBER_JOINED
  TASK_COMPLETED
  FEEDBACK_ASSIGNED
  FEEDBACK_SUBMITTED
  FEEDBACK_REASSIGNED

  @@schema("core")
}

enum FeedbackStatus {
  ASSIGNED
  COMPLETED
  REASSIGNED
  UNASSIGNED

  @@schema("core")
}

enum NotificationType {
  EVALUATION_COMPLETED
  EVALUATION_REVIEW_FLAGGED
  EVALUATION_REVIEW_RESOLVED
  PEER_FEEDBACK_AVAILABLE
  PEER_FEEDBACK_RECEIVED
  ANNOUNCEMENT_POSTED
  CONTRIBUTION_TO_DOMAIN
  TASK_ASSIGNED
  ARTICLE_FEEDBACK
  ARTICLE_PUBLISHED
  EDITOR_APPLICATION_SUBMITTED
  ROLE_CHANGED

  @@schema("core")
}

enum EvaluationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED

  @@schema("evaluation")
}

enum EvaluationModelStatus {
  ACTIVE
  DEPRECATED
  RETIRED

  @@schema("evaluation")
}

enum EvaluationReviewStatus {
  PENDING
  CONFIRMED
  OVERRIDDEN

  @@schema("evaluation")
}

// ─── Core Schema ────────────────────────────────────────────────────────────

model Contributor {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  githubId   Int               @unique @map("github_id")
  githubUsername String?       @unique @map("github_username")
  email      String?           @unique
  name       String
  bio        String?           @db.VarChar(500)
  avatarUrl  String?           @map("avatar_url")
  domain     ContributorDomain?
  skillAreas String[]          @default([]) @map("skill_areas")
  role       ContributorRole   @default(PUBLIC)
  isActive   Boolean           @default(true) @map("is_active")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  buddyOptIn             Boolean           @default(false) @map("buddy_opt_in")
  showEvaluationScores   Boolean           @default(false) @map("show_evaluation_scores")

  auditLogs              AuditLog[]
  applications           Application[]    @relation("ApplicationContributor")
  reviewedApplications   Application[]    @relation("ApplicationReviewer")
  applicationReviews     ApplicationReview[] @relation("ReviewAuthor")
  buddyAssignments       BuddyAssignment[] @relation("BuddyMentee")
  buddyMentees           BuddyAssignment[] @relation("BuddyMentor")
  onboardingMilestones   OnboardingMilestone[]
  monitoredRepositories  MonitoredRepository[]
  contributions              Contribution[]
  collaborations             ContributionCollaboration[]
  collaborationOverrides     ContributionCollaboration[] @relation("CollaborationOverriddenBy")
  workingGroupMemberships    WorkingGroupMember[]
  claimedTasks               Task[]              @relation("TaskClaimer")
  createdTasks               Task[]              @relation("TaskCreator")
  ledWorkingGroups           WorkingGroup[]      @relation("WorkingGroupLead")
  announcements              Announcement[]
  activityEvents             ActivityEvent[]
  notifications              Notification[]
  peerFeedbacksGiven         PeerFeedback[]      @relation("ReviewerFeedbacks")
  platformSettings           PlatformSetting[]
  evaluations                Evaluation[]
  evaluationReviewsAsContributor EvaluationReview[] @relation("EvaluationReviewContributor")
  evaluationReviewsAsReviewer    EvaluationReview[] @relation("EvaluationReviewReviewer")
  articles               Article[]            @relation("ArticleAuthor")
  editedArticles         Article[]            @relation("ArticleEditor")
  articleVersions        ArticleVersion[]     @relation("ArticleVersionCreator")
  editorialFeedback      EditorialFeedback[]  @relation("EditorialFeedbackEditor")
  editorialInlineComments InlineComment[]     @relation("InlineCommentEditor")
  editorApplications     EditorApplication[]  @relation("EditorApplicationContributor")
  reviewedEditorApps     EditorApplication[]  @relation("EditorApplicationReviewedBy")
  revokedEditorApps      EditorApplication[]  @relation("EditorApplicationRevokedBy")
  updatedEditorCriteria  EditorEligibilityCriteria[] @relation("EditorCriteriaUpdatedBy")
  authorRewardAllocations  ArticleRewardAllocation[] @relation("AuthorRewardAllocations")
  editorRewardAllocations  ArticleRewardAllocation[] @relation("EditorRewardAllocations")
  moderationActions        ModerationReport[]        @relation("ModerationAdmin")
  dataExportRequests       DataExportRequest[]       @relation("DataExportRequests")
  dataDeletionRequests     DataDeletionRequest[]     @relation("DataDeletionRequests")
  reviewedComplianceDocs   ComplianceDocument[]      @relation("ComplianceDocumentReviewer")

  @@map("contributors")
  @@schema("core")
}

model Application {
  id                     String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicantName          String            @map("applicant_name")
  applicantEmail         String            @map("applicant_email")
  domain                 ContributorDomain
  statementOfInterest    String            @map("statement_of_interest") @db.VarChar(300)
  microTaskDomain        ContributorDomain @map("micro_task_domain")
  microTaskResponse      String            @map("micro_task_response")
  microTaskSubmissionUrl String?           @map("micro_task_submission_url")
  gdprConsentVersion     String            @map("gdpr_consent_version")
  gdprConsentedAt        DateTime          @map("gdpr_consented_at")
  status                 ApplicationStatus @default(PENDING)
  contributorId          String?           @map("contributor_id") @db.Uuid
  reviewedById           String?           @map("reviewed_by_id") @db.Uuid
  reviewedAt             DateTime?         @map("reviewed_at")
  declineReason          String?           @map("decline_reason")
  ignitionStartedAt      DateTime?         @map("ignition_started_at")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  contributor            Contributor?      @relation("ApplicationContributor", fields: [contributorId], references: [id])
  reviewedBy             Contributor?      @relation("ApplicationReviewer", fields: [reviewedById], references: [id])
  reviews                ApplicationReview[]

  @@map("applications")
  @@unique([applicantEmail], map: "applications_applicant_email_key")
  @@schema("core")
}

model ApplicationReview {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId    String               @map("application_id") @db.Uuid
  reviewerId       String               @map("reviewer_id") @db.Uuid
  recommendation   ReviewRecommendation?
  feedback         String?
  submittedAt      DateTime?            @map("submitted_at")
  createdAt        DateTime             @default(now()) @map("created_at")

  application      Application          @relation(fields: [applicationId], references: [id])
  reviewer         Contributor          @relation("ReviewAuthor", fields: [reviewerId], references: [id])

  @@map("application_reviews")
  @@schema("core")
}

model MicroTask {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domain              ContributorDomain
  title               String
  description         String
  expectedDeliverable String            @map("expected_deliverable")
  estimatedEffort     String            @map("estimated_effort")
  submissionFormat    String            @map("submission_format")
  isActive            Boolean           @default(true) @map("is_active")
  deactivatedAt       DateTime?         @map("deactivated_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@map("micro_tasks")
  @@schema("core")
}

model BuddyAssignment {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId  String            @map("contributor_id") @db.Uuid
  buddyId        String            @map("buddy_id") @db.Uuid
  assignedAt     DateTime          @default(now()) @map("assigned_at")
  expiresAt      DateTime          @map("expires_at")
  isActive       Boolean           @default(true) @map("is_active")
  notes          String?

  contributor    Contributor       @relation("BuddyMentee", fields: [contributorId], references: [id])
  buddy          Contributor       @relation("BuddyMentor", fields: [buddyId], references: [id])

  @@map("buddy_assignments")
  @@schema("core")
}

model OnboardingMilestone {
  id             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId  String                   @map("contributor_id") @db.Uuid
  milestoneType  OnboardingMilestoneType  @map("milestone_type")
  completedAt    DateTime                 @default(now()) @map("completed_at")
  metadata       Json?

  contributor    Contributor              @relation(fields: [contributorId], references: [id])

  @@unique([contributorId, milestoneType], map: "onboarding_milestones_contributor_type_key")
  @@map("onboarding_milestones")
  @@schema("core")
}

model MonitoredRepository {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner          String
  repo           String
  fullName       String           @unique @map("full_name")
  webhookId      Int?             @map("webhook_id")
  webhookSecret  String           @map("webhook_secret")
  status         RepositoryStatus @default(PENDING)
  statusMessage  String?          @map("status_message")
  addedById      String           @map("added_by_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  addedBy            Contributor         @relation(fields: [addedById], references: [id])
  contributions      Contribution[]
  webhookDeliveries  WebhookDelivery[]

  @@unique([owner, repo], map: "monitored_repositories_owner_repo_key")
  @@map("monitored_repositories")
  @@schema("core")
}

model Contribution {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId    String?            @map("contributor_id") @db.Uuid
  taskId           String?            @map("task_id") @db.Uuid
  repositoryId     String             @map("repository_id") @db.Uuid
  source           ContributionSource @default(GITHUB)
  sourceRef        String             @map("source_ref")
  contributionType ContributionType   @map("contribution_type")
  title            String
  description      String?            @db.Text
  rawData          Json               @map("raw_data")
  normalizedAt     DateTime           @default(now()) @map("normalized_at")
  status           ContributionStatus @default(INGESTED)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  contributor      Contributor?        @relation(fields: [contributorId], references: [id])
  task             Task?               @relation(fields: [taskId], references: [id])
  repository       MonitoredRepository @relation(fields: [repositoryId], references: [id])
  collaborations   ContributionCollaboration[]
  peerFeedbacks    PeerFeedback[]      @relation("ContributionFeedbacks")
  evaluations      Evaluation[]

  @@unique([source, repositoryId, sourceRef], map: "contributions_source_repo_ref_key")
  @@index([contributorId, createdAt(sort: Desc)], map: "contributions_contributor_created_idx")
  @@index([taskId], map: "contributions_task_id_idx")
  @@index([repositoryId, contributionType], map: "contributions_repo_type_idx")
  @@map("contributions")
  @@schema("core")
}

model ContributionCollaboration {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributionId    String              @map("contribution_id") @db.Uuid
  contributorId     String              @map("contributor_id") @db.Uuid
  isCurrent         Boolean             @default(true) @map("is_current")
  role              CollaborationRole
  splitPercentage   Float               @default(100.0) @map("split_percentage")
  status            CollaborationStatus @default(DETECTED)
  detectionSource   String              @map("detection_source")
  confirmedAt       DateTime?           @map("confirmed_at")
  disputeComment    String?             @map("dispute_comment")
  overriddenById    String?             @map("overridden_by_id") @db.Uuid
  overrideReason    String?             @map("override_reason")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  contribution      Contribution        @relation(fields: [contributionId], references: [id])
  contributor       Contributor         @relation(fields: [contributorId], references: [id])
  overriddenBy      Contributor?        @relation("CollaborationOverriddenBy", fields: [overriddenById], references: [id])

  @@unique([contributionId, contributorId, isCurrent], map: "contribution_collaborations_current_key")
  @@index([contributionId], map: "idx_contribution_collaborations_contribution")
  @@index([contributorId], map: "idx_contribution_collaborations_contributor")
  @@index([contributionId, isCurrent], map: "idx_contribution_collaborations_current")
  @@index([status], map: "idx_contribution_collaborations_status")
  @@map("contribution_collaborations")
  @@schema("core")
}

model WebhookDelivery {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deliveryId    String                @unique @map("delivery_id")
  repositoryId  String                @map("repository_id") @db.Uuid
  eventType     String                @map("event_type")
  status        WebhookDeliveryStatus @default(RECEIVED)
  payload       Json?
  processedAt   DateTime?             @map("processed_at")
  createdAt     DateTime              @default(now()) @map("created_at")

  repository    MonitoredRepository   @relation(fields: [repositoryId], references: [id])

  @@index([repositoryId], map: "webhook_deliveries_repo_idx")
  @@map("webhook_deliveries")
  @@schema("core")
}

model WorkingGroup {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String            @unique
  description        String
  domain             ContributorDomain @unique
  accentColor        String            @map("accent_color")
  memberCount        Int               @default(0) @map("member_count")
  leadContributorId  String?           @map("lead_contributor_id") @db.Uuid
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  members            WorkingGroupMember[]
  leadContributor    Contributor?      @relation("WorkingGroupLead", fields: [leadContributorId], references: [id])
  announcements      Announcement[]

  @@map("working_groups")
  @@schema("core")
}

model WorkingGroupMember {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workingGroupId  String       @map("working_group_id") @db.Uuid
  contributorId   String       @map("contributor_id") @db.Uuid
  joinedAt        DateTime     @default(now()) @map("joined_at")

  workingGroup    WorkingGroup @relation(fields: [workingGroupId], references: [id])
  contributor     Contributor  @relation(fields: [contributorId], references: [id])

  @@unique([workingGroupId, contributorId], map: "working_group_members_group_contributor_key")
  @@index([contributorId], map: "idx_working_group_members_contributor_id")
  @@index([workingGroupId], map: "idx_working_group_members_working_group_id")
  @@map("working_group_members")
  @@schema("core")
}

model Announcement {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workingGroupId  String       @map("working_group_id") @db.Uuid
  authorId        String       @map("author_id") @db.Uuid
  content         String       @db.VarChar(500)
  createdAt       DateTime     @default(now()) @map("created_at")

  workingGroup    WorkingGroup @relation(fields: [workingGroupId], references: [id])
  author          Contributor  @relation(fields: [authorId], references: [id])

  @@index([workingGroupId, createdAt(sort: Desc)], map: "idx_announcements_working_group_id_created_at")
  @@map("announcements")
  @@schema("core")
}

model Task {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  description     String            @db.Text
  domain          ContributorDomain
  difficulty      TaskDifficulty
  estimatedEffort String            @map("estimated_effort")
  status          TaskStatus        @default(AVAILABLE)
  sortOrder       Int               @default(0) @map("sort_order")
  claimedById     String?           @map("claimed_by_id") @db.Uuid
  claimedAt       DateTime?         @map("claimed_at")
  completedAt     DateTime?         @map("completed_at")
  createdById     String            @map("created_by_id") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  claimedBy       Contributor?      @relation("TaskClaimer", fields: [claimedById], references: [id])
  createdBy       Contributor       @relation("TaskCreator", fields: [createdById], references: [id])
  contributions   Contribution[]

  @@index([domain, status], map: "idx_tasks_domain_status")
  @@index([domain, sortOrder], map: "idx_tasks_domain_sort_order")
  @@index([claimedById], map: "idx_tasks_claimed_by_id")
  @@index([status], map: "idx_tasks_status")
  @@index([createdById], map: "idx_tasks_created_by_id")
  @@map("tasks")
  @@schema("core")
}

model ActivityEvent {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType        ActivityEventType @map("event_type")
  title            String
  description      String?
  contributorId    String            @map("contributor_id") @db.Uuid
  domain           ContributorDomain
  contributionType ContributionType? @map("contribution_type")
  entityId         String            @map("entity_id")
  metadata         Json?
  createdAt        DateTime          @default(now()) @map("created_at")

  contributor      Contributor       @relation(fields: [contributorId], references: [id])

  @@index([createdAt(sort: Desc)], map: "idx_activity_events_created_at")
  @@index([domain, createdAt(sort: Desc)], map: "idx_activity_events_domain_created_at")
  @@index([contributorId], map: "idx_activity_events_contributor_id")
  @@map("activity_events")
  @@schema("core")
}

model Notification {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId String           @map("contributor_id") @db.Uuid
  type          NotificationType
  title         String
  description   String?
  entityId      String           @map("entity_id")
  category      String
  read          Boolean          @default(false)
  createdAt     DateTime         @default(now()) @map("created_at")
  readAt        DateTime?        @map("read_at")

  contributor   Contributor      @relation(fields: [contributorId], references: [id])

  @@index([contributorId, read, createdAt(sort: Desc)], map: "idx_notifications_contributor_unread")
  @@index([contributorId, createdAt(sort: Desc)], map: "idx_notifications_contributor_created")
  @@index([contributorId, category, read], map: "idx_notifications_contributor_category")
  @@map("notifications")
  @@schema("core")
}

model PeerFeedback {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributionId  String         @map("contribution_id") @db.Uuid
  reviewerId      String         @map("reviewer_id") @db.Uuid
  status          FeedbackStatus @default(ASSIGNED)
  ratings         Json?
  comments        String?        @db.Text
  assignedBy      String?        @map("assigned_by") @db.Uuid
  assignedAt      DateTime       @default(now()) @map("assigned_at")
  submittedAt     DateTime?      @map("submitted_at")
  reassignedAt    DateTime?      @map("reassigned_at")
  reassignReason  String?        @map("reassign_reason")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  contribution    Contribution   @relation("ContributionFeedbacks", fields: [contributionId], references: [id])
  reviewer        Contributor    @relation("ReviewerFeedbacks", fields: [reviewerId], references: [id])

  @@unique([contributionId, reviewerId], map: "peer_feedbacks_contribution_reviewer_key")
  @@index([reviewerId, status], map: "idx_peer_feedback_reviewer_status")
  @@index([contributionId], map: "idx_peer_feedback_contribution")
  @@index([status, assignedAt], map: "idx_peer_feedback_status_assigned")
  @@map("peer_feedbacks")
  @@schema("core")
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  updater   Contributor? @relation(fields: [updatedBy], references: [id])

  @@map("platform_settings")
  @@schema("core")
}

// ─── Audit Schema ───────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId       String?  @map("actor_id") @db.Uuid
  actorRole     String?  @map("actor_role")
  action        String
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  details       Json?
  previousState Json?    @map("previous_state")
  newState      Json?    @map("new_state")
  reason        String?
  correlationId String?  @map("correlation_id")
  createdAt     DateTime @default(now()) @map("created_at")

  actor         Contributor? @relation(fields: [actorId], references: [id])

  @@index([createdAt])
  @@index([action])
  @@index([entityId])
  @@index([actorId])
  @@index([correlationId])
  @@map("audit_logs")
  @@schema("audit")
}

model ConsentRecord {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  consentType    String   @map("consent_type")
  consentVersion String   @map("consent_version")
  accepted       Boolean
  acceptedAt     DateTime @map("accepted_at")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")

  @@map("consent_records")
  @@schema("audit")
}

model DataExportRequest {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId String    @map("contributor_id") @db.Uuid
  status        String    @default("PENDING")
  requestedAt   DateTime  @default(now()) @map("requested_at")
  completedAt   DateTime? @map("completed_at")
  expiresAt     DateTime? @map("expires_at")
  downloadUrl   String?   @map("download_url")
  fileName      String?   @map("file_name")
  correlationId String?   @map("correlation_id")
  errorMessage  String?   @map("error_message")

  contributor   Contributor @relation("DataExportRequests", fields: [contributorId], references: [id])

  @@index([contributorId, requestedAt(sort: Desc)], map: "idx_data_export_contributor_requested")
  @@index([status], map: "idx_data_export_status")
  @@map("data_export_requests")
  @@schema("audit")
}

model DataDeletionRequest {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId    String    @map("contributor_id") @db.Uuid
  status           String    @default("PENDING")
  requestedAt      DateTime  @default(now()) @map("requested_at")
  coolingOffEndsAt DateTime  @map("cooling_off_ends_at")
  confirmedAt      DateTime? @map("confirmed_at")
  completedAt      DateTime? @map("completed_at")
  pseudonymId      String?   @map("pseudonym_id")
  correlationId    String?   @map("correlation_id")
  cancelledAt      DateTime? @map("cancelled_at")
  cancelReason     String?   @map("cancel_reason")

  contributor      Contributor @relation("DataDeletionRequests", fields: [contributorId], references: [id])

  @@index([contributorId, requestedAt(sort: Desc)], map: "idx_data_deletion_contributor_requested")
  @@index([status, coolingOffEndsAt], map: "idx_data_deletion_status_cooling")
  @@map("data_deletion_requests")
  @@schema("audit")
}

model ComplianceDocument {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentType    String    @map("document_type")
  version         Int       @default(1)
  content         String    @db.Text
  format          String    @default("json")
  generatedAt     DateTime  @default(now()) @map("generated_at")
  legalReviewedAt DateTime? @map("legal_reviewed_at")
  legalReviewedBy String?   @map("legal_reviewed_by") @db.Uuid
  reviewNotes     String?   @map("review_notes") @db.Text
  retiredAt       DateTime? @map("retired_at")
  relatedModelId  String?   @map("related_model_id")
  correlationId   String?   @map("correlation_id")

  reviewer        Contributor? @relation("ComplianceDocumentReviewer", fields: [legalReviewedBy], references: [id])

  @@index([documentType, version(sort: Desc)], map: "idx_compliance_doc_type_version")
  @@index([generatedAt(sort: Desc)], map: "idx_compliance_doc_generated")
  @@map("compliance_documents")
  @@schema("audit")
}

// ─── Publication Schema ─────────────────────────────────────────────────────

enum ArticleStatus {
  DRAFT
  SUBMITTED
  EDITORIAL_REVIEW
  REVISION_REQUESTED
  APPROVED
  PUBLISHED
  ARCHIVED

  @@schema("publication")
}

enum EditorialDecision {
  APPROVE
  REQUEST_REVISIONS
  REJECT

  @@schema("publication")
}

enum EditorApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED

  @@schema("publication")
}

model Article {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId    String            @map("author_id") @db.Uuid
  title       String            @db.VarChar(200)
  slug        String            @unique
  abstract    String            @db.VarChar(300)
  body        String            @db.Text
  domain      ContributorDomain
  status      ArticleStatus     @default(DRAFT)
  version     Int               @default(1)
  editorId    String?           @map("editor_id") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  submittedAt DateTime?         @map("submitted_at")
  publishedAt DateTime?         @map("published_at")

  author             Contributor              @relation("ArticleAuthor", fields: [authorId], references: [id])
  editor             Contributor?             @relation("ArticleEditor", fields: [editorId], references: [id])
  versions           ArticleVersion[]
  feedback           EditorialFeedback[]
  inlineComments     InlineComment[]
  views              ArticleView[]
  rewardAllocation   ArticleRewardAllocation?
  moderationReports  ModerationReport[]

  @@index([authorId, status], map: "idx_articles_author_id_status")
  @@index([editorId, status], map: "idx_articles_editor_id_status")
  @@index([domain, status], map: "idx_articles_domain_status")
  @@index([status, publishedAt(sort: Desc)], map: "idx_articles_status_published_at")
  @@map("articles")
  @@schema("publication")
}

model ArticleVersion {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  articleId     String      @map("article_id") @db.Uuid
  versionNumber Int         @map("version_number")
  body          String      @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")
  createdById   String      @map("created_by_id") @db.Uuid

  article   Article     @relation(fields: [articleId], references: [id])
  createdBy Contributor @relation("ArticleVersionCreator", fields: [createdById], references: [id])

  @@index([articleId, versionNumber], map: "idx_article_versions_article_version")
  @@map("article_versions")
  @@schema("publication")
}

model EditorialFeedback {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  articleId         String            @map("article_id") @db.Uuid
  editorId          String            @map("editor_id") @db.Uuid
  decision          EditorialDecision
  overallAssessment String            @map("overall_assessment") @db.Text
  revisionRequests  Json?             @map("revision_requests")
  articleVersion    Int               @map("article_version")
  createdAt         DateTime          @default(now()) @map("created_at")

  article        Article         @relation(fields: [articleId], references: [id])
  editor         Contributor     @relation("EditorialFeedbackEditor", fields: [editorId], references: [id])
  inlineComments InlineComment[]

  @@index([articleId], map: "idx_editorial_feedback_article_id")
  @@map("editorial_feedback")
  @@schema("publication")
}

model InlineComment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feedbackId     String   @map("feedback_id") @db.Uuid
  articleId      String   @map("article_id") @db.Uuid
  editorId       String   @map("editor_id") @db.Uuid
  content        String   @db.Text
  highlightStart Int      @map("highlight_start")
  highlightEnd   Int      @map("highlight_end")
  articleVersion Int      @map("article_version")
  resolved       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  feedback EditorialFeedback @relation(fields: [feedbackId], references: [id])
  article  Article           @relation(fields: [articleId], references: [id])
  editor   Contributor       @relation("InlineCommentEditor", fields: [editorId], references: [id])

  @@index([articleId, articleVersion], map: "idx_inline_comments_article_id_version")
  @@map("inline_comments")
  @@schema("publication")
}

model EditorApplication {
  id                   String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId        String                  @map("contributor_id") @db.Uuid
  domain               ContributorDomain
  status               EditorApplicationStatus @default(PENDING)
  applicationStatement String                  @map("application_statement") @db.VarChar(300)
  reviewedById         String?                 @map("reviewed_by_id") @db.Uuid
  reviewedAt           DateTime?               @map("reviewed_at")
  reviewNotes          String?                 @map("review_notes") @db.Text
  revokedAt            DateTime?               @map("revoked_at")
  revokedById          String?                 @map("revoked_by_id") @db.Uuid
  revokeReason         String?                 @map("revoke_reason") @db.Text
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  contributor Contributor  @relation("EditorApplicationContributor", fields: [contributorId], references: [id])
  reviewedBy  Contributor? @relation("EditorApplicationReviewedBy", fields: [reviewedById], references: [id])
  revokedBy   Contributor? @relation("EditorApplicationRevokedBy", fields: [revokedById], references: [id])

  @@unique([contributorId, domain], map: "editor_applications_contributor_domain_key")
  @@index([status], map: "idx_editor_application_status")
  @@index([contributorId], map: "idx_editor_application_contributor_id")
  @@map("editor_applications")
  @@schema("publication")
}

model EditorEligibilityCriteria {
  id                       String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domain                   ContributorDomain @unique
  minContributionCount     Int               @default(10) @map("min_contribution_count")
  minGovernanceWeight      Decimal           @default(0) @map("min_governance_weight") @db.Decimal(5, 2)
  maxConcurrentAssignments Int               @default(5) @map("max_concurrent_assignments")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  updatedById              String?           @map("updated_by_id") @db.Uuid

  updatedBy Contributor? @relation("EditorCriteriaUpdatedBy", fields: [updatedById], references: [id])

  @@map("editor_eligibility_criteria")
  @@schema("publication")
}

model ArticleView {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  articleId          String   @map("article_id") @db.Uuid
  viewedAt           DateTime @default(now()) @map("viewed_at")
  referralSource     String?  @map("referral_source")
  timeOnPageSeconds  Int?     @map("time_on_page_seconds")
  scrollDepthPercent Int?     @map("scroll_depth_percent")
  visitorHash        String   @map("visitor_hash") @db.VarChar(16)

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, viewedAt(sort: Desc)], map: "idx_article_views_article_viewed_at")
  @@index([articleId, visitorHash], map: "idx_article_views_dedup")
  @@map("article_views")
  @@schema("publication")
}

model ArticleRewardAllocation {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  articleId          String   @unique @map("article_id") @db.Uuid
  evaluationId       String?  @map("evaluation_id") @db.Uuid
  compositeScore     Decimal? @map("composite_score") @db.Decimal(5, 2)
  authorId           String   @map("author_id") @db.Uuid
  editorId           String?  @map("editor_id") @db.Uuid
  authorSharePercent Int      @default(80) @map("author_share_percent")
  editorSharePercent Int      @default(20) @map("editor_share_percent")
  allocatedAt        DateTime @default(now()) @map("allocated_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  article Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author  Contributor  @relation("AuthorRewardAllocations", fields: [authorId], references: [id])
  editor  Contributor? @relation("EditorRewardAllocations", fields: [editorId], references: [id])

  @@index([authorId], map: "idx_article_reward_author")
  @@index([editorId], map: "idx_article_reward_editor")
  @@map("article_reward_allocations")
  @@schema("publication")
}

model ModerationReport {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  articleId       String   @map("article_id") @db.Uuid
  plagiarismScore Decimal  @default(0) @map("plagiarism_score") @db.Decimal(5, 2)
  aiContentScore  Decimal  @default(0) @map("ai_content_score") @db.Decimal(5, 2)
  flagType        String?  @map("flag_type") @db.VarChar(50)
  isFlagged       Boolean  @default(false) @map("is_flagged")
  flaggedPassages Json?    @map("flagged_passages")
  status          String   @default("PENDING") @db.VarChar(30)
  adminId         String?  @map("admin_id") @db.Uuid
  adminAction     String?  @map("admin_action") @db.VarChar(50)
  adminReason     String?  @map("admin_reason") @db.Text
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  article Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  admin   Contributor? @relation("ModerationAdmin", fields: [adminId], references: [id])

  @@index([articleId], map: "idx_moderation_reports_article_id")
  @@index([isFlagged, status], map: "idx_moderation_reports_flagged_status")
  @@map("moderation_reports")
  @@schema("publication")
}

// ─── Reward Scoring Enums ────────────────────────────────────────────────────

enum TemporalHorizon {
  SESSION
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY

  @@schema("evaluation")
}

enum ScoreTrend {
  RISING
  STABLE
  DECLINING

  @@schema("evaluation")
}

// ─── Evaluation Schema ──────────────────────────────────────────────────────

model EvaluationModel {
  id             String                @id @db.Uuid
  name           String
  version        String
  provider       String
  apiModelId     String                @map("api_model_id")
  evaluationType String                @map("evaluation_type")
  config         Json?
  configHash     String?               @map("config_hash")
  status         EvaluationModelStatus @default(ACTIVE)
  deployedAt     DateTime?             @map("deployed_at")
  retiredAt      DateTime?             @map("retired_at")
  createdAt      DateTime              @default(now()) @map("created_at")

  evaluations Evaluation[]

  @@unique([apiModelId, version, evaluationType])
  @@index([evaluationType, status])
  @@map("evaluation_models")
  @@schema("evaluation")
}

model EvaluationRubric {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  evaluationType String   @map("evaluation_type")
  documentType   String?  @map("document_type")
  parameters     Json
  version        String
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  evaluations    Evaluation[]

  @@index([evaluationType, isActive], map: "idx_rubrics_type_active")
  @@map("evaluation_rubrics")
  @@schema("evaluation")
}

model Evaluation {
  id              String            @id @db.Uuid
  contributionId  String            @map("contribution_id") @db.Uuid
  contributorId   String            @map("contributor_id") @db.Uuid
  modelId         String?           @map("model_id") @db.Uuid
  rubricId        String?           @map("rubric_id") @db.Uuid
  status          EvaluationStatus  @default(PENDING)
  compositeScore  Decimal?          @map("composite_score") @db.Decimal(5, 2)
  dimensionScores Json?             @map("dimension_scores")
  narrative       String?           @db.Text
  formulaVersion  String?           @map("formula_version")
  rawInputs       Json?             @map("raw_inputs")
  metadata        Json?
  startedAt       DateTime?         @map("started_at")
  completedAt     DateTime?         @map("completed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  contribution    Contribution      @relation(fields: [contributionId], references: [id])
  contributor     Contributor       @relation(fields: [contributorId], references: [id])
  model           EvaluationModel?  @relation(fields: [modelId], references: [id])
  rubric          EvaluationRubric? @relation(fields: [rubricId], references: [id])
  review          EvaluationReview?

  @@unique([contributionId])
  @@index([contributorId, createdAt], map: "idx_evaluations_contributor_created")
  @@index([status], map: "idx_evaluations_status")
  @@map("evaluations")
  @@schema("evaluation")
}

model EvaluationReview {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  evaluationId      String                  @unique @map("evaluation_id") @db.Uuid
  contributorId     String                  @map("contributor_id") @db.Uuid
  reviewerId        String?                 @map("reviewer_id") @db.Uuid
  status            EvaluationReviewStatus  @default(PENDING)
  flagReason        String                  @map("flag_reason") @db.Text
  reviewReason      String?                 @map("review_reason") @db.Text
  originalScores    Json                    @map("original_scores")
  overrideScores    Json?                   @map("override_scores")
  overrideNarrative String?                 @map("override_narrative") @db.Text
  flaggedAt         DateTime                @default(now()) @map("flagged_at")
  resolvedAt        DateTime?               @map("resolved_at")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  evaluation        Evaluation              @relation(fields: [evaluationId], references: [id])
  contributor       Contributor             @relation("EvaluationReviewContributor", fields: [contributorId], references: [id])
  reviewer          Contributor?            @relation("EvaluationReviewReviewer", fields: [reviewerId], references: [id])

  @@index([status, flaggedAt], map: "idx_evaluation_reviews_status_flagged")
  @@map("evaluation_reviews")
  @@schema("evaluation")
}

// ─── Reward Scoring Models ──────────────────────────────────────────────────

model ScoringFormulaVersion {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  version            Int       @default(autoincrement())
  aiEvalWeight       Decimal   @default(0.40) @map("ai_eval_weight") @db.Decimal(3, 2)
  peerFeedbackWeight Decimal   @default(0.25) @map("peer_feedback_weight") @db.Decimal(3, 2)
  complexityWeight   Decimal   @default(0.20) @map("complexity_weight") @db.Decimal(3, 2)
  domainNormWeight   Decimal   @default(0.15) @map("domain_norm_weight") @db.Decimal(3, 2)
  effectiveFrom      DateTime  @default(now()) @map("effective_from")
  effectiveTo        DateTime? @map("effective_to")
  createdBy          String    @map("created_by") @db.Uuid
  metadata           Json?
  createdAt          DateTime  @default(now()) @map("created_at")

  scores ContributionScore[]

  @@map("scoring_formula_versions")
  @@schema("evaluation")
}

model ContributionScore {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributionId       String   @unique @map("contribution_id") @db.Uuid
  contributorId        String   @map("contributor_id") @db.Uuid
  compositeScore       Decimal  @map("composite_score") @db.Decimal(5, 2)
  aiEvalScore          Decimal  @map("ai_eval_score") @db.Decimal(5, 2)
  peerFeedbackScore    Decimal? @map("peer_feedback_score") @db.Decimal(5, 2)
  complexityMultiplier Decimal  @default(1.00) @map("complexity_multiplier") @db.Decimal(5, 2)
  domainNormFactor     Decimal  @default(1.00) @map("domain_norm_factor") @db.Decimal(5, 2)
  formulaVersionId     String   @map("formula_version_id") @db.Uuid
  rawInputs            Json?    @map("raw_inputs")
  createdAt            DateTime @default(now()) @map("created_at")

  formulaVersion ScoringFormulaVersion @relation(fields: [formulaVersionId], references: [id])

  @@index([contributorId, createdAt(sort: Desc)], map: "idx_contribution_scores_contributor_created")
  @@map("contribution_scores")
  @@schema("evaluation")
}

model TemporalScoreAggregate {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId     String          @map("contributor_id") @db.Uuid
  horizon           TemporalHorizon
  periodStart       DateTime        @map("period_start")
  periodEnd         DateTime        @map("period_end")
  aggregatedScore   Decimal         @map("aggregated_score") @db.Decimal(5, 2)
  contributionCount Int             @default(0) @map("contribution_count")
  trend             ScoreTrend      @default(STABLE)
  computedAt        DateTime        @default(now()) @map("computed_at")

  @@unique([contributorId, horizon, periodStart], map: "temporal_score_aggregates_contributor_horizon_period_key")
  @@index([contributorId, horizon, periodStart(sort: Desc)], map: "idx_temporal_aggregates_contributor_horizon_period")
  @@map("temporal_score_aggregates")
  @@schema("evaluation")
}
