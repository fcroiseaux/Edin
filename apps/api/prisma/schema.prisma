// ─── Publication Schema ─────────────────────────────────────────────────────

enum ArticleStatus {
  DRAFT
  SUBMITTED
  EDITORIAL_REVIEW
  REVISION_REQUESTED
  APPROVED
  PUBLISHED
  ARCHIVED

  @@schema("publication")
}

enum EditorialDecision {
  APPROVE
  REQUEST_REVISIONS
  REJECT

  @@schema("publication")
}

enum EditorApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED

  @@schema("publication")
}

model Article {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId    String            @map("author_id") @db.Uuid
  title       String            @db.VarChar(200)
  slug        String            @unique
  abstract    String            @db.VarChar(300)
  body        String            @db.Text
  domain      ContributorDomain
  status      ArticleStatus     @default(DRAFT)
  version     Int               @default(1)
  editorId    String?           @map("editor_id") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  submittedAt DateTime?         @map("submitted_at")
  publishedAt DateTime?         @map("published_at")

  author            Contributor              @relation("ArticleAuthor", fields: [authorId], references: [id])
  editor            Contributor?             @relation("ArticleEditor", fields: [editorId], references: [id])
  versions          ArticleVersion[]
  feedback          EditorialFeedback[]
  inlineComments    InlineComment[]
  views             ArticleView[]
  rewardAllocation  ArticleRewardAllocation?
  moderationReports ModerationReport[]

  @@index([authorId, status], map: "idx_articles_author_id_status")
  @@index([editorId, status], map: "idx_articles_editor_id_status")
  @@index([domain, status], map: "idx_articles_domain_status")
  @@index([status, publishedAt(sort: Desc)], map: "idx_articles_status_published_at")
  @@map("articles")
  @@schema("publication")
}

model ArticleVersion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  articleId     String   @map("article_id") @db.Uuid
  versionNumber Int      @map("version_number")
  body          String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  createdById   String   @map("created_by_id") @db.Uuid

  article   Article     @relation(fields: [articleId], references: [id])
  createdBy Contributor @relation("ArticleVersionCreator", fields: [createdById], references: [id])

  @@index([articleId, versionNumber], map: "idx_article_versions_article_version")
  @@map("article_versions")
  @@schema("publication")
}

model EditorialFeedback {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  articleId         String            @map("article_id") @db.Uuid
  editorId          String            @map("editor_id") @db.Uuid
  decision          EditorialDecision
  overallAssessment String            @map("overall_assessment") @db.Text
  revisionRequests  Json?             @map("revision_requests")
  articleVersion    Int               @map("article_version")
  createdAt         DateTime          @default(now()) @map("created_at")

  article        Article         @relation(fields: [articleId], references: [id])
  editor         Contributor     @relation("EditorialFeedbackEditor", fields: [editorId], references: [id])
  inlineComments InlineComment[]

  @@index([articleId], map: "idx_editorial_feedback_article_id")
  @@map("editorial_feedback")
  @@schema("publication")
}

model InlineComment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feedbackId     String   @map("feedback_id") @db.Uuid
  articleId      String   @map("article_id") @db.Uuid
  editorId       String   @map("editor_id") @db.Uuid
  content        String   @db.Text
  highlightStart Int      @map("highlight_start")
  highlightEnd   Int      @map("highlight_end")
  articleVersion Int      @map("article_version")
  resolved       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  feedback EditorialFeedback @relation(fields: [feedbackId], references: [id])
  article  Article           @relation(fields: [articleId], references: [id])
  editor   Contributor       @relation("InlineCommentEditor", fields: [editorId], references: [id])

  @@index([articleId, articleVersion], map: "idx_inline_comments_article_id_version")
  @@map("inline_comments")
  @@schema("publication")
}

model EditorApplication {
  id                   String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId        String                  @map("contributor_id") @db.Uuid
  domain               ContributorDomain
  status               EditorApplicationStatus @default(PENDING)
  applicationStatement String                  @map("application_statement") @db.VarChar(300)
  reviewedById         String?                 @map("reviewed_by_id") @db.Uuid
  reviewedAt           DateTime?               @map("reviewed_at")
  reviewNotes          String?                 @map("review_notes") @db.Text
  revokedAt            DateTime?               @map("revoked_at")
  revokedById          String?                 @map("revoked_by_id") @db.Uuid
  revokeReason         String?                 @map("revoke_reason") @db.Text
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  contributor Contributor  @relation("EditorApplicationContributor", fields: [contributorId], references: [id])
  reviewedBy  Contributor? @relation("EditorApplicationReviewedBy", fields: [reviewedById], references: [id])
  revokedBy   Contributor? @relation("EditorApplicationRevokedBy", fields: [revokedById], references: [id])

  @@unique([contributorId, domain], map: "editor_applications_contributor_domain_key")
  @@index([status], map: "idx_editor_application_status")
  @@index([contributorId], map: "idx_editor_application_contributor_id")
  @@map("editor_applications")
  @@schema("publication")
}

model EditorEligibilityCriteria {
  id                       String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domain                   ContributorDomain @unique
  minContributionCount     Int               @default(10) @map("min_contribution_count")
  minGovernanceWeight      Decimal           @default(0) @map("min_governance_weight") @db.Decimal(5, 2)
  maxConcurrentAssignments Int               @default(5) @map("max_concurrent_assignments")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  updatedById              String?           @map("updated_by_id") @db.Uuid

  updatedBy Contributor? @relation("EditorCriteriaUpdatedBy", fields: [updatedById], references: [id])

  @@map("editor_eligibility_criteria")
  @@schema("publication")
}

model ArticleView {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  articleId          String   @map("article_id") @db.Uuid
  viewedAt           DateTime @default(now()) @map("viewed_at")
  referralSource     String?  @map("referral_source")
  timeOnPageSeconds  Int?     @map("time_on_page_seconds")
  scrollDepthPercent Int?     @map("scroll_depth_percent")
  visitorHash        String   @map("visitor_hash") @db.VarChar(16)

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, viewedAt(sort: Desc)], map: "idx_article_views_article_viewed_at")
  @@index([articleId, visitorHash], map: "idx_article_views_dedup")
  @@map("article_views")
  @@schema("publication")
}

model ArticleRewardAllocation {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  articleId          String   @unique @map("article_id") @db.Uuid
  evaluationId       String?  @map("evaluation_id") @db.Uuid
  compositeScore     Decimal? @map("composite_score") @db.Decimal(5, 2)
  authorId           String   @map("author_id") @db.Uuid
  editorId           String?  @map("editor_id") @db.Uuid
  authorSharePercent Int      @default(80) @map("author_share_percent")
  editorSharePercent Int      @default(20) @map("editor_share_percent")
  allocatedAt        DateTime @default(now()) @map("allocated_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  article Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author  Contributor  @relation("AuthorRewardAllocations", fields: [authorId], references: [id])
  editor  Contributor? @relation("EditorRewardAllocations", fields: [editorId], references: [id])

  @@index([authorId], map: "idx_article_reward_author")
  @@index([editorId], map: "idx_article_reward_editor")
  @@map("article_reward_allocations")
  @@schema("publication")
}

model ModerationReport {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  articleId       String    @map("article_id") @db.Uuid
  plagiarismScore Decimal   @default(0) @map("plagiarism_score") @db.Decimal(5, 2)
  aiContentScore  Decimal   @default(0) @map("ai_content_score") @db.Decimal(5, 2)
  flagType        String?   @map("flag_type") @db.VarChar(50)
  isFlagged       Boolean   @default(false) @map("is_flagged")
  flaggedPassages Json?     @map("flagged_passages")
  status          String    @default("PENDING") @db.VarChar(30)
  adminId         String?   @map("admin_id") @db.Uuid
  adminAction     String?   @map("admin_action") @db.VarChar(50)
  adminReason     String?   @map("admin_reason") @db.Text
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  article Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  admin   Contributor? @relation("ModerationAdmin", fields: [adminId], references: [id])

  @@index([articleId], map: "idx_moderation_reports_article_id")
  @@index([isFlagged, status], map: "idx_moderation_reports_flagged_status")
  @@map("moderation_reports")
  @@schema("publication")
}

// ─── Reward Scoring Enums ────────────────────────────────────────────────────

enum TemporalHorizon {
  SESSION
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY

  @@schema("evaluation")
}

enum ScoreTrend {
  RISING
  STABLE
  DECLINING

  @@schema("evaluation")
}

// ─── Evaluation Schema ──────────────────────────────────────────────────────

model EvaluationModel {
  id             String                @id @db.Uuid
  name           String
  version        String
  provider       String
  apiModelId     String                @map("api_model_id")
  evaluationType String                @map("evaluation_type")
  config         Json?
  configHash     String?               @map("config_hash")
  status         EvaluationModelStatus @default(ACTIVE)
  deployedAt     DateTime?             @map("deployed_at")
  retiredAt      DateTime?             @map("retired_at")
  createdAt      DateTime              @default(now()) @map("created_at")

  evaluations Evaluation[]

  @@unique([apiModelId, version, evaluationType])
  @@index([evaluationType, status])
  @@map("evaluation_models")
  @@schema("evaluation")
}

model EvaluationRubric {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  evaluationType String   @map("evaluation_type")
  documentType   String?  @map("document_type")
  parameters     Json
  version        String
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  evaluations Evaluation[]

  @@index([evaluationType, isActive], map: "idx_rubrics_type_active")
  @@map("evaluation_rubrics")
  @@schema("evaluation")
}

model Evaluation {
  id              String           @id @db.Uuid
  contributionId  String           @map("contribution_id") @db.Uuid
  contributorId   String           @map("contributor_id") @db.Uuid
  modelId         String?          @map("model_id") @db.Uuid
  rubricId        String?          @map("rubric_id") @db.Uuid
  status          EvaluationStatus @default(PENDING)
  compositeScore  Decimal?         @map("composite_score") @db.Decimal(5, 2)
  dimensionScores Json?            @map("dimension_scores")
  narrative       String?          @db.Text
  formulaVersion  String?          @map("formula_version")
  rawInputs       Json?            @map("raw_inputs")
  metadata        Json?
  startedAt       DateTime?        @map("started_at")
  completedAt     DateTime?        @map("completed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  contribution Contribution      @relation(fields: [contributionId], references: [id])
  contributor  Contributor       @relation(fields: [contributorId], references: [id])
  model        EvaluationModel?  @relation(fields: [modelId], references: [id])
  rubric       EvaluationRubric? @relation(fields: [rubricId], references: [id])
  review       EvaluationReview?

  @@unique([contributionId])
  @@index([contributorId, createdAt], map: "idx_evaluations_contributor_created")
  @@index([status], map: "idx_evaluations_status")
  @@map("evaluations")
  @@schema("evaluation")
}

model EvaluationReview {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  evaluationId      String                 @unique @map("evaluation_id") @db.Uuid
  contributorId     String                 @map("contributor_id") @db.Uuid
  reviewerId        String?                @map("reviewer_id") @db.Uuid
  status            EvaluationReviewStatus @default(PENDING)
  flagReason        String                 @map("flag_reason") @db.Text
  reviewReason      String?                @map("review_reason") @db.Text
  originalScores    Json                   @map("original_scores")
  overrideScores    Json?                  @map("override_scores")
  overrideNarrative String?                @map("override_narrative") @db.Text
  flaggedAt         DateTime               @default(now()) @map("flagged_at")
  resolvedAt        DateTime?              @map("resolved_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  evaluation  Evaluation   @relation(fields: [evaluationId], references: [id])
  contributor Contributor  @relation("EvaluationReviewContributor", fields: [contributorId], references: [id])
  reviewer    Contributor? @relation("EvaluationReviewReviewer", fields: [reviewerId], references: [id])

  @@index([status, flaggedAt], map: "idx_evaluation_reviews_status_flagged")
  @@map("evaluation_reviews")
  @@schema("evaluation")
}

// ─── Reward Scoring Models ──────────────────────────────────────────────────

model ScoringFormulaVersion {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  version            Int       @default(autoincrement())
  aiEvalWeight       Decimal   @default(0.40) @map("ai_eval_weight") @db.Decimal(3, 2)
  peerFeedbackWeight Decimal   @default(0.25) @map("peer_feedback_weight") @db.Decimal(3, 2)
  complexityWeight   Decimal   @default(0.20) @map("complexity_weight") @db.Decimal(3, 2)
  domainNormWeight   Decimal   @default(0.15) @map("domain_norm_weight") @db.Decimal(3, 2)
  effectiveFrom      DateTime  @default(now()) @map("effective_from")
  effectiveTo        DateTime? @map("effective_to")
  createdBy          String    @map("created_by") @db.Uuid
  metadata           Json?
  createdAt          DateTime  @default(now()) @map("created_at")

  scores ContributionScore[]

  @@map("scoring_formula_versions")
  @@schema("evaluation")
}

model ContributionScore {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributionId       String   @unique @map("contribution_id") @db.Uuid
  contributorId        String   @map("contributor_id") @db.Uuid
  compositeScore       Decimal  @map("composite_score") @db.Decimal(5, 2)
  aiEvalScore          Decimal  @map("ai_eval_score") @db.Decimal(5, 2)
  peerFeedbackScore    Decimal? @map("peer_feedback_score") @db.Decimal(5, 2)
  complexityMultiplier Decimal  @default(1.00) @map("complexity_multiplier") @db.Decimal(5, 2)
  domainNormFactor     Decimal  @default(1.00) @map("domain_norm_factor") @db.Decimal(5, 2)
  formulaVersionId     String   @map("formula_version_id") @db.Uuid
  rawInputs            Json?    @map("raw_inputs")
  createdAt            DateTime @default(now()) @map("created_at")

  formulaVersion ScoringFormulaVersion @relation(fields: [formulaVersionId], references: [id])

  @@index([contributorId, createdAt(sort: Desc)], map: "idx_contribution_scores_contributor_created")
  @@map("contribution_scores")
  @@schema("evaluation")
}

model TemporalScoreAggregate {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId     String          @map("contributor_id") @db.Uuid
  horizon           TemporalHorizon
  periodStart       DateTime        @map("period_start")
  periodEnd         DateTime        @map("period_end")
  aggregatedScore   Decimal         @map("aggregated_score") @db.Decimal(5, 2)
  contributionCount Int             @default(0) @map("contribution_count")
  trend             ScoreTrend      @default(STABLE)
  computedAt        DateTime        @default(now()) @map("computed_at")

  @@unique([contributorId, horizon, periodStart], map: "temporal_score_aggregates_contributor_horizon_period_key")
  @@index([contributorId, horizon, periodStart(sort: Desc)], map: "idx_temporal_aggregates_contributor_horizon_period")
  @@map("temporal_score_aggregates")
  @@schema("evaluation")
}

// ─── Track Record Evaluation Stream ─────────────────────────────────────────

enum TrackRecordMilestoneType {
  CONSISTENCY
  DURATION
  VOLUME
  CROSS_DOMAIN
  CUSTOM

  @@schema("evaluation")
}

model TrackRecordEvaluation {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId            String   @map("contributor_id") @db.Uuid
  evaluationPeriodStart    DateTime @map("evaluation_period_start")
  evaluationPeriodEnd      DateTime @map("evaluation_period_end")
  consistencyScore         Decimal  @map("consistency_score") @db.Decimal(5, 2)
  engagementDurationMonths Int      @map("engagement_duration_months")
  contributionCount        Int      @map("contribution_count")
  domainBreadth            Int      @map("domain_breadth")
  activeWeeksRatio         Decimal  @map("active_weeks_ratio") @db.Decimal(3, 2)
  computedAt               DateTime @default(now()) @map("computed_at")
  metadata                 Json?

  contributor Contributor @relation(fields: [contributorId], references: [id])

  @@index([contributorId, computedAt(sort: Desc)], map: "idx_track_record_evals_contributor_computed")
  @@index([computedAt(sort: Desc)], map: "idx_track_record_evals_computed")
  @@map("track_record_evaluations")
  @@schema("evaluation")
}

model TrackRecordMilestone {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId           String                   @map("contributor_id") @db.Uuid
  milestoneType           TrackRecordMilestoneType @map("milestone_type")
  thresholdName           String                   @map("threshold_name")
  thresholdConfigSnapshot Json                     @map("threshold_config_snapshot")
  crossedAt               DateTime                 @default(now()) @map("crossed_at")
  metadata                Json?

  contributor Contributor          @relation(fields: [contributorId], references: [id])
  outcomes    TrackRecordOutcome[]

  @@unique([contributorId, milestoneType, thresholdName], map: "uq_track_record_milestones_contributor_type_name")
  @@index([contributorId, crossedAt(sort: Desc)], map: "idx_track_record_milestones_contributor_crossed")
  @@index([milestoneType], map: "idx_track_record_milestones_type")
  @@map("track_record_milestones")
  @@schema("evaluation")
}

model TrackRecordThresholdConfig {
  id             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  milestoneType  TrackRecordMilestoneType @map("milestone_type")
  thresholdName  String                   @map("threshold_name")
  thresholdRules Json                     @map("threshold_rules")
  outcomeType    String                   @map("outcome_type")
  isActive       Boolean                  @default(true) @map("is_active")
  createdAt      DateTime                 @default(now()) @map("created_at")

  @@unique([milestoneType, thresholdName], map: "uq_threshold_config_type_name")
  @@index([isActive], map: "idx_threshold_config_active")
  @@map("track_record_threshold_config")
  @@schema("evaluation")
}

enum TrackRecordOutcomeType {
  ROLE_ELIGIBILITY
  SALARY_TIER
  SERVICE_ACCESS
  INVITATION
  CUSTOM

  @@schema("evaluation")
}

enum TrackRecordOutcomeStatus {
  ACTIVE
  EXPIRED
  REVOKED

  @@schema("evaluation")
}

model TrackRecordOutcome {
  id             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  milestoneId    String                   @map("milestone_id") @db.Uuid
  contributorId  String                   @map("contributor_id") @db.Uuid
  outcomeType    TrackRecordOutcomeType   @map("outcome_type")
  outcomeDetails Json                     @map("outcome_details")
  grantedAt      DateTime                 @default(now()) @map("granted_at")
  expiresAt      DateTime?                @map("expires_at")
  status         TrackRecordOutcomeStatus @default(ACTIVE) @map("status")
  metadata       Json?

  milestone   TrackRecordMilestone @relation(fields: [milestoneId], references: [id])
  contributor Contributor          @relation(fields: [contributorId], references: [id])

  @@unique([milestoneId, outcomeType], map: "uq_track_record_outcomes_milestone_type")
  @@index([contributorId, status], map: "idx_track_record_outcomes_contributor_status")
  @@index([outcomeType], map: "idx_track_record_outcomes_type")
  @@map("track_record_outcomes")
  @@schema("evaluation")
}

// ─── Sprint Schema ──────────────────────────────────────────────────────────

enum ZenhubSyncType {
  WEBHOOK
  POLL
  BACKFILL

  @@schema("sprint")
}

enum ZenhubSyncStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  FAILED

  @@schema("sprint")
}

model ZenhubSync {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deliveryId    String           @unique @map("delivery_id")
  syncType      ZenhubSyncType   @map("sync_type")
  status        ZenhubSyncStatus @default(RECEIVED)
  eventType     String           @map("event_type")
  payload       Json?
  correlationId String?          @map("correlation_id")
  errorMessage  String?          @map("error_message")
  retryCount    Int              @default(0) @map("retry_count")
  receivedAt    DateTime         @default(now()) @map("received_at")
  processedAt   DateTime?        @map("processed_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@index([syncType, status], map: "zenhub_syncs_type_status_idx")
  @@index([receivedAt], map: "zenhub_syncs_received_at_idx")
  @@map("zenhub_syncs")
  @@schema("sprint")
}

model ZenhubSyncConflict {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  syncId           String?  @map("sync_id") @db.Uuid
  conflictType     String   @map("conflict_type")
  affectedEntity   String   @map("affected_entity")
  affectedEntityId String   @map("affected_entity_id")
  resolution       String   @default("pending")
  outcome          String?
  occurredAt       DateTime @map("occurred_at")
  resolvedBy       String?  @map("resolved_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([resolution, occurredAt], map: "zenhub_sync_conflicts_resolution_occurred_idx")
  @@map("zenhub_sync_conflicts")
  @@schema("sprint")
}

model SprintMetric {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sprintId           String   @map("sprint_id")
  sprintName         String   @map("sprint_name")
  sprintStart        DateTime @map("sprint_start")
  sprintEnd          DateTime @map("sprint_end")
  domain             String?
  velocity           Int      @default(0)
  committedPoints    Int      @default(0) @map("committed_points")
  deliveredPoints    Int      @default(0) @map("delivered_points")
  burndownData       Json?    @map("burndown_data")
  cycleTimeAvg       Float?   @map("cycle_time_avg")
  leadTimeAvg        Float?   @map("lead_time_avg")
  scopeChanges       Int      @default(0) @map("scope_changes")
  estimationAccuracy Float?   @map("estimation_accuracy")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  pipelineTransitions    PipelineTransition[]
  scopeChangeRecords     ScopeChange[]
  contributorEstimations ContributorSprintEstimation[]

  @@unique([sprintId, domain], map: "sprint_metrics_sprint_domain_uq")
  @@index([sprintEnd, domain], map: "sprint_metrics_sprint_end_domain_idx")
  @@map("sprint_metrics")
  @@schema("sprint")
}

model PipelineTransition {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sprintMetricId String   @map("sprint_metric_id") @db.Uuid
  issueId        String   @map("issue_id")
  issueNumber    Int      @map("issue_number")
  fromPipeline   String   @map("from_pipeline")
  toPipeline     String   @map("to_pipeline")
  storyPoints    Int?     @map("story_points")
  contributorId  String?  @map("contributor_id") @db.Uuid
  transitionedAt DateTime @map("transitioned_at")
  createdAt      DateTime @default(now()) @map("created_at")

  sprintMetric SprintMetric @relation(fields: [sprintMetricId], references: [id], onDelete: Cascade)

  @@index([sprintMetricId, transitionedAt], map: "pipeline_transitions_sprint_transitioned_idx")
  @@index([issueId], map: "pipeline_transitions_issue_idx")
  @@map("pipeline_transitions")
  @@schema("sprint")
}

enum ScopeChangeType {
  ADDED
  REMOVED

  @@schema("sprint")
}

model ScopeChange {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sprintMetricId String          @map("sprint_metric_id") @db.Uuid
  issueId        String          @map("issue_id")
  issueNumber    Int             @map("issue_number")
  changeType     ScopeChangeType @map("change_type")
  storyPoints    Int?            @map("story_points")
  changedAt      DateTime        @map("changed_at")
  createdAt      DateTime        @default(now()) @map("created_at")

  sprintMetric SprintMetric @relation(fields: [sprintMetricId], references: [id], onDelete: Cascade)

  @@index([sprintMetricId, changedAt], map: "scope_changes_sprint_changed_idx")
  @@map("scope_changes")
  @@schema("sprint")
}

model ContributorSprintEstimation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sprintMetricId  String   @map("sprint_metric_id") @db.Uuid
  contributorId   String   @map("contributor_id") @db.Uuid
  plannedPoints   Int      @default(0) @map("planned_points")
  deliveredPoints Int      @default(0) @map("delivered_points")
  accuracy        Float?   @map("accuracy")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  sprintMetric SprintMetric @relation(fields: [sprintMetricId], references: [id], onDelete: Cascade)

  @@unique([sprintMetricId, contributorId], map: "contributor_sprint_estimation_sprint_contributor_uq")
  @@index([contributorId], map: "contributor_sprint_estimation_contributor_idx")
  @@map("contributor_sprint_estimations")
  @@schema("sprint")
}

model ContributionSprintContext {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributionId String   @map("contribution_id") @db.Uuid
  sprintId       String   @map("sprint_id")
  storyPoints    Int?     @map("story_points")
  zenhubIssueId  String   @map("zenhub_issue_id")
  epicId         String?  @map("epic_id")
  pipelineStatus String?  @map("pipeline_status")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([contributionId, sprintId], map: "contribution_sprint_context_contribution_sprint_uq")
  @@index([sprintId], map: "contribution_sprint_context_sprint_idx")
  @@index([contributionId], map: "contribution_sprint_context_contribution_idx")
  @@index([zenhubIssueId], map: "contribution_sprint_context_issue_idx")
  @@map("contribution_sprint_context")
  @@schema("sprint")
}

model PlanningReliability {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId      String   @map("contributor_id") @db.Uuid
  sprintId           String   @map("sprint_id")
  committedPoints    Int      @default(0) @map("committed_points")
  deliveredPoints    Int      @default(0) @map("delivered_points")
  deliveryRatio      Float?   @map("delivery_ratio")
  estimationVariance Float?   @map("estimation_variance")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([contributorId, sprintId], map: "planning_reliability_contributor_sprint_uq")
  @@index([contributorId], map: "planning_reliability_contributor_idx")
  @@index([sprintId], map: "planning_reliability_sprint_idx")
  @@map("planning_reliability")
  @@schema("sprint")
}

model CrossDomainCollaboration {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sprintId          String   @map("sprint_id")
  epicId            String?  @map("epic_id")
  domains           String[]
  contributorIds    String[] @map("contributor_ids") @db.Uuid
  collaborationType String   @default("sprint") @map("collaboration_type")
  detectedAt        DateTime @default(now()) @map("detected_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([sprintId, epicId, collaborationType], map: "cross_domain_collab_sprint_epic_type_uq")
  @@index([sprintId], map: "cross_domain_collab_sprint_idx")
  @@index([detectedAt], map: "cross_domain_collab_detected_idx")
  @@map("cross_domain_collaborations")
  @@schema("sprint")
}
