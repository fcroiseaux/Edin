// Edin Platform — Prisma Schema
// Domain-separated PostgreSQL schemas: core, evaluation, publication, audit

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["core", "evaluation", "publication", "audit"]
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum ContributorRole {
  PUBLIC
  APPLICANT
  CONTRIBUTOR
  EDITOR
  FOUNDING_CONTRIBUTOR
  WORKING_GROUP_LEAD
  ADMIN

  @@schema("core")
}

enum ContributorDomain {
  Technology
  Fintech
  Impact
  Governance

  @@schema("core")
}

// ─── Core Schema ────────────────────────────────────────────────────────────

model Contributor {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  githubId   Int               @unique @map("github_id")
  email      String?           @unique
  name       String
  bio        String?           @db.VarChar(500)
  avatarUrl  String?           @map("avatar_url")
  domain     ContributorDomain?
  skillAreas String[]          @default([]) @map("skill_areas")
  role       ContributorRole   @default(PUBLIC)
  isActive   Boolean           @default(true) @map("is_active")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  auditLogs  AuditLog[]

  @@map("contributors")
  @@schema("core")
}

// ─── Audit Schema ───────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId       String?  @map("actor_id") @db.Uuid
  action        String
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  details       Json?
  correlationId String?  @map("correlation_id")
  createdAt     DateTime @default(now()) @map("created_at")

  actor         Contributor? @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
  @@schema("audit")
}
