// Edin Platform — Prisma Schema
// Domain-separated PostgreSQL schemas: core, evaluation, publication, audit

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["core", "evaluation", "publication", "audit"]
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum ContributorRole {
  PUBLIC
  APPLICANT
  CONTRIBUTOR
  EDITOR
  FOUNDING_CONTRIBUTOR
  WORKING_GROUP_LEAD
  ADMIN

  @@schema("core")
}

enum ContributorDomain {
  Technology
  Fintech
  Impact
  Governance

  @@schema("core")
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  DECLINED

  @@schema("core")
}

enum ReviewRecommendation {
  APPROVE
  REQUEST_MORE_INFO
  DECLINE

  @@schema("core")
}

enum OnboardingMilestoneType {
  ACCOUNT_ACTIVATED
  BUDDY_ASSIGNED
  FIRST_TASK_VIEWED
  FIRST_TASK_CLAIMED
  FIRST_CONTRIBUTION_SUBMITTED

  @@schema("core")
}

enum RepositoryStatus {
  ACTIVE
  PENDING
  ERROR
  REMOVING

  @@schema("core")
}

// ─── Core Schema ────────────────────────────────────────────────────────────

model Contributor {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  githubId   Int               @unique @map("github_id")
  email      String?           @unique
  name       String
  bio        String?           @db.VarChar(500)
  avatarUrl  String?           @map("avatar_url")
  domain     ContributorDomain?
  skillAreas String[]          @default([]) @map("skill_areas")
  role       ContributorRole   @default(PUBLIC)
  isActive   Boolean           @default(true) @map("is_active")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  buddyOptIn Boolean           @default(false) @map("buddy_opt_in")

  auditLogs              AuditLog[]
  applications           Application[]    @relation("ApplicationContributor")
  reviewedApplications   Application[]    @relation("ApplicationReviewer")
  applicationReviews     ApplicationReview[] @relation("ReviewAuthor")
  buddyAssignments       BuddyAssignment[] @relation("BuddyMentee")
  buddyMentees           BuddyAssignment[] @relation("BuddyMentor")
  onboardingMilestones   OnboardingMilestone[]
  monitoredRepositories  MonitoredRepository[]

  @@map("contributors")
  @@schema("core")
}

model Application {
  id                     String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicantName          String            @map("applicant_name")
  applicantEmail         String            @map("applicant_email")
  domain                 ContributorDomain
  statementOfInterest    String            @map("statement_of_interest") @db.VarChar(300)
  microTaskDomain        ContributorDomain @map("micro_task_domain")
  microTaskResponse      String            @map("micro_task_response")
  microTaskSubmissionUrl String?           @map("micro_task_submission_url")
  gdprConsentVersion     String            @map("gdpr_consent_version")
  gdprConsentedAt        DateTime          @map("gdpr_consented_at")
  status                 ApplicationStatus @default(PENDING)
  contributorId          String?           @map("contributor_id") @db.Uuid
  reviewedById           String?           @map("reviewed_by_id") @db.Uuid
  reviewedAt             DateTime?         @map("reviewed_at")
  declineReason          String?           @map("decline_reason")
  ignitionStartedAt      DateTime?         @map("ignition_started_at")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  contributor            Contributor?      @relation("ApplicationContributor", fields: [contributorId], references: [id])
  reviewedBy             Contributor?      @relation("ApplicationReviewer", fields: [reviewedById], references: [id])
  reviews                ApplicationReview[]

  @@map("applications")
  @@unique([applicantEmail], map: "applications_applicant_email_key")
  @@schema("core")
}

model ApplicationReview {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId    String               @map("application_id") @db.Uuid
  reviewerId       String               @map("reviewer_id") @db.Uuid
  recommendation   ReviewRecommendation?
  feedback         String?
  submittedAt      DateTime?            @map("submitted_at")
  createdAt        DateTime             @default(now()) @map("created_at")

  application      Application          @relation(fields: [applicationId], references: [id])
  reviewer         Contributor          @relation("ReviewAuthor", fields: [reviewerId], references: [id])

  @@map("application_reviews")
  @@schema("core")
}

model MicroTask {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domain              ContributorDomain
  title               String
  description         String
  expectedDeliverable String            @map("expected_deliverable")
  estimatedEffort     String            @map("estimated_effort")
  submissionFormat    String            @map("submission_format")
  isActive            Boolean           @default(true) @map("is_active")
  deactivatedAt       DateTime?         @map("deactivated_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@map("micro_tasks")
  @@schema("core")
}

model BuddyAssignment {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId  String            @map("contributor_id") @db.Uuid
  buddyId        String            @map("buddy_id") @db.Uuid
  assignedAt     DateTime          @default(now()) @map("assigned_at")
  expiresAt      DateTime          @map("expires_at")
  isActive       Boolean           @default(true) @map("is_active")
  notes          String?

  contributor    Contributor       @relation("BuddyMentee", fields: [contributorId], references: [id])
  buddy          Contributor       @relation("BuddyMentor", fields: [buddyId], references: [id])

  @@map("buddy_assignments")
  @@schema("core")
}

model OnboardingMilestone {
  id             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contributorId  String                   @map("contributor_id") @db.Uuid
  milestoneType  OnboardingMilestoneType  @map("milestone_type")
  completedAt    DateTime                 @default(now()) @map("completed_at")
  metadata       Json?

  contributor    Contributor              @relation(fields: [contributorId], references: [id])

  @@unique([contributorId, milestoneType], map: "onboarding_milestones_contributor_type_key")
  @@map("onboarding_milestones")
  @@schema("core")
}

model MonitoredRepository {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner          String
  repo           String
  fullName       String           @unique @map("full_name")
  webhookId      Int?             @map("webhook_id")
  webhookSecret  String           @map("webhook_secret")
  status         RepositoryStatus @default(PENDING)
  statusMessage  String?          @map("status_message")
  addedById      String           @map("added_by_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  addedBy        Contributor      @relation(fields: [addedById], references: [id])

  @@unique([owner, repo], map: "monitored_repositories_owner_repo_key")
  @@map("monitored_repositories")
  @@schema("core")
}

// ─── Audit Schema ───────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId       String?  @map("actor_id") @db.Uuid
  action        String
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  details       Json?
  correlationId String?  @map("correlation_id")
  createdAt     DateTime @default(now()) @map("created_at")

  actor         Contributor? @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
  @@schema("audit")
}

model ConsentRecord {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  consentType    String   @map("consent_type")
  consentVersion String   @map("consent_version")
  accepted       Boolean
  acceptedAt     DateTime @map("accepted_at")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")

  @@map("consent_records")
  @@schema("audit")
}
