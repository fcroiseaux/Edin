  @@index([editionId, algorithmicRank], map: "idx_newspaper_items_edition_rank")
  @@index([channelId], map: "idx_newspaper_items_channel")
  @@index([editionId, channelId], map: "idx_newspaper_items_edition_channel")
  @@index([sourceEventId], map: "idx_newspaper_items_source_event")
  @@index([significanceScore(sort: Desc)], map: "idx_newspaper_items_significance")
  @@map("newspaper_items")
  @@schema("core")
}

model NewspaperItemVote {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  newspaperItemId String   @map("newspaper_item_id") @db.Uuid
  voterId         String   @map("voter_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  newspaperItem NewspaperItem @relation(fields: [newspaperItemId], references: [id], onDelete: Cascade)
  voter         Contributor   @relation("NewspaperItemVotes", fields: [voterId], references: [id])

  @@unique([newspaperItemId, voterId], map: "uq_newspaper_item_votes_item_voter")
  @@index([newspaperItemId], map: "idx_newspaper_item_votes_item_id")
  @@index([voterId], map: "idx_newspaper_item_votes_voter_id")
  @@map("newspaper_item_votes")
  @@schema("core")
}

// ─── Audit Schema ───────────────────────────────────────────────────────────

model AuditLog {
