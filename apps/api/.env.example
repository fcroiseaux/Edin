# API Environment Variables
DATABASE_URL=postgresql://edin:edin_dev_password@localhost:5432/edin?schema=core
REDIS_URL=redis://localhost:6379
API_PORT=3001
API_HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=debug
OTEL_SERVICE_NAME=edin-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# GitHub API / Repository ingestion
# Personal Access Token used by the EDIN bot account to verify repositories and
# register webhooks. Required scopes:
#   - `admin:repo_hook`  (needed for ALL repositories to register/delete webhooks)
#   - `repo`             (needed additionally for PRIVATE repositories)
# For private repos the bot account must also be added as a Collaborator (Read
# access) on the target repository by its owner.
GITHUB_APP_TOKEN=
# Optional username of the EDIN bot GitHub account. Surfaced in error messages
# and in the admin UI help block so private-repo owners know who to invite.
GITHUB_BOT_USERNAME=

# AI Evaluation
ANTHROPIC_API_KEY=
EVALUATION_MODEL_ID=claude-sonnet-4-5-20250514
EVALUATION_ENABLED=true

# JWT & Token Configuration
JWT_SECRET=your_jwt_secret_at_least_32_chars_long
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=30d
