# =============================================================================
# Edin Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# Database (PostgreSQL)
DATABASE_URL=postgresql://edin:edin_dev_password@localhost:5432/edin?schema=core

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# GitHub OAuth (Story 1.3)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# JWT (Story 1.3)
# JWT_SECRET=
# JWT_EXPIRATION=15m
# REFRESH_TOKEN_EXPIRATION=30d

# GitHub Integration (Story 4-1)
# Token with admin:repo_hook scope for webhook management
# GITHUB_APP_TOKEN=github_pat_...
# Public URL where GitHub sends webhooks
# INGESTION_WEBHOOK_BASE_URL=https://api.edin.dev

# OpenTelemetry
OTEL_SERVICE_NAME=edin-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Logging
LOG_LEVEL=debug
